# Copia a `.env.local` y rellena con valores reales. No subas secretos al repositorio.

# Neon (PostgreSQL). En Vercel: Settings → Environment Variables → misma cadena en
# Production y Preview (o "All Environments") y luego Redeploy.
#
# La app acepta cualquiera de estos nombres (el primero que exista):
# DATABASE_URL, POSTGRES_URL, POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING
DATABASE_URL=

# --- Login multi-usuario ---
# Con DATABASE_URL + SESSION_SECRET la app exige iniciar sesión; cada usuario tiene
# su propio JSON en `finance_state`. Los usuarios se crean con:
#   npm run db:push
#   CREATE_USER_PASSWORD='...' npm run db:create-user -- mi.usuario
# (en producción puedes apuntar DATABASE_URL de Neon desde tu máquina para crear usuarios).
#
# SESSION_SECRET=mínimo-16-caracteres-aleatorios-para-firmar-la-cookie-jwt
#
# Generar SESSION_SECRET: openssl rand -base64 32
#
# Migración desde una sola fila (id=default): ver `npm run db:migrate-multi-user`
# (respalda JSON en ./backups/ y crea users + finance_state nuevas).
#
# Sacar JSON desde Neon sin botón dedicado: consola SQL →
#   SELECT payload::text FROM finance_state WHERE id = 'default';
# (o desde la tabla en "Tables" abrir la fila y copiar el campo payload).
#
# --- Hogar compartido + calendario (tablas households, household_members, …) ---
# Si `npm run db:push` pide TTY: `npm run db:apply-household-ddl` (SQL idempotente en Neon).
# Crear hogar y asociar todos los usuarios: npm run db:ensure-household
#
# --- Recordatorios por correo (Vercel Cron, cada hora) ---
# CRON_SECRET=igual que en Vercel → Settings → Cron Jobs (o variable CRON_SECRET)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=onboarding@resend.dev  (o tu dominio verificado en Resend)
